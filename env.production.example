# 🚀 FUZO Multi-Tenant SaaS Environment Variables
# Copy this file to .env.local and fill in your actual values

# ================================
# 🔐 SUPABASE CORE (REQUIRED)
# ================================
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT Configuration
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings
VITE_SUPABASE_AUTH_REDIRECT_URL=https://fuzo.app/auth/callback

# ================================
# 🏢 MULTI-TENANT CONFIGURATION
# ================================
VITE_DEFAULT_TENANT_PLAN=beta
VITE_MAX_BETA_USERS=50
VITE_BETA_ACCESS_CODE=FUZO_BETA_2024
VITE_REQUIRE_INVITATION=true
VITE_BETA_MODE=true

# Beta User Limits
VITE_BETA_SAVED_RESTAURANTS_LIMIT=100
VITE_BETA_ROUTES_LIMIT=10
VITE_BETA_FRIENDS_LIMIT=25

# ================================
# 🗺️ GOOGLE MAPS PLATFORM (REQUIRED)
# ================================
VITE_GOOGLE_MAPS_API_KEY=AIzaSyAiwdvjMrC6-BjYRBaERbGhwFB6GXdQJu4
VITE_GOOGLE_PLACES_API_KEY=AIzaSyAiwdvjMrC6-BjYRBaERbGhwFB6GXdQJu4
VITE_GOOGLE_DIRECTIONS_API_KEY=AIzaSyAiwdvjMrC6-BjYRBaERbGhwFB6GXdQJu4
VITE_GOOGLE_GEOCODING_API_KEY=AIzaSyAiwdvjMrC6-BjYRBaERbGhwFB6GXdQJu4

# ================================
# 🍽️ RESTAURANT DATA APIS (OPTIONAL)
# ================================
VITE_YELP_API_KEY=Bearer your-yelp-api-key
VITE_FOURSQUARE_API_KEY=fsq3your-foursquare-key
VITE_ZOMATO_API_KEY=your-zomato-api-key
VITE_SPOONACULAR_API_KEY=your-spoonacular-key

# ================================
# 🤖 AI & MACHINE LEARNING (OPTIONAL)
# ================================
VITE_OPENAI_API_KEY=sk-your-openai-key
VITE_OPENAI_MODEL=gpt-4
VITE_OPENAI_MAX_TOKENS=500
VITE_ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ================================
# 📸 MEDIA & STORAGE
# ================================
# Cloudinary (Recommended for image uploads)
VITE_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
VITE_CLOUDINARY_API_KEY=123456789012345
VITE_CLOUDINARY_API_SECRET=your-cloudinary-secret
VITE_CLOUDINARY_UPLOAD_PRESET=fuzo_uploads

# AWS S3 Alternative
VITE_AWS_S3_BUCKET=fuzo-user-uploads
VITE_AWS_REGION=ap-south-1
VITE_AWS_ACCESS_KEY_ID=AKIA...
VITE_AWS_SECRET_ACCESS_KEY=...

# ================================
# 💳 PAYMENTS & BILLING (FUTURE)
# ================================
# Stripe (International)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Razorpay (India)
VITE_RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# ================================
# 📧 COMMUNICATION SERVICES
# ================================
# Email Services
VITE_RESEND_API_KEY=re_...
SENDGRID_API_KEY=SG....

# SMS Services
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1234567890

# Push Notifications
VITE_VAPID_PUBLIC_KEY=BH...
VAPID_PRIVATE_KEY=...

# ================================
# 📊 ANALYTICS & MONITORING
# ================================
# User Analytics
VITE_POSTHOG_KEY=phc_...
VITE_MIXPANEL_TOKEN=...
VITE_GA_MEASUREMENT_ID=G-...

# Error Tracking
VITE_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=...

# Performance Monitoring
VITE_VERCEL_ANALYTICS_ID=...

# ================================
# 🔒 SECURITY & API CONFIGURATION
# ================================
VITE_API_BASE_URL=https://api.fuzo.app
API_RATE_LIMIT_MAX=100
API_RATE_LIMIT_WINDOW=60000
ENCRYPTION_KEY=your-32-character-encryption-key

# ================================
# 🌍 ENVIRONMENT CONFIGURATION
# ================================
NODE_ENV=production
VITE_APP_ENV=production
VITE_DEBUG_MODE=false
VITE_ENABLE_DATA_EXPORT=true

# ================================
# 🧪 BETA TESTING CONFIGURATION
# ================================
VITE_BETA_SIGNUP_ENABLED=false
VITE_INVITE_ONLY=true
VITE_BETA_WAITLIST_ENABLED=true
VITE_MAX_DAILY_SIGNUPS=5

# Social Features Toggle
VITE_ENABLE_SOCIAL_FEATURES=false
VITE_ENABLE_ROUTE_SHARING=false
VITE_ENABLE_AI_RECOMMENDATIONS=false

# ================================
# 📱 PWA CONFIGURATION
# ================================
VITE_PWA_NAME=FUZO - Food Discovery
VITE_PWA_SHORT_NAME=FUZO
VITE_PWA_THEME_COLOR=#ff6b35
VITE_PWA_BACKGROUND_COLOR=#ffffff 